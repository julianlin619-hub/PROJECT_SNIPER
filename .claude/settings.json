{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run dev:*)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run start)",
      "Bash(npm install:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find . :*)",
      "Bash(find src:*)",
      "Bash(find scripts:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ffprobe:*)",
      "Bash(python3 scripts/*)",
      "Bash(.venv/bin/python3 scripts/*)",
      "Bash(node:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
